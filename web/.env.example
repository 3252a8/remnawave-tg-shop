# Backend API for the portal
WEB_API_URL=http://remnawave-tg-shop:8080

# Session cookie settings used by the SvelteKit BFF layer
WEB_SESSION_COOKIE_NAME=remnawave_web_session
WEB_SESSION_COOKIE_SECURE=false
WEB_SESSION_COOKIE_SAMESITE=lax
WEB_SESSION_COOKIE_PATH=/
WEB_SESSION_COOKIE_DOMAIN=
WEB_SESSION_TTL_DAYS=30

# Brevo SMTP is configured in the main project .env because the backend sends portal email codes.

# Optional direct TLS for the web container
WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_SSL_CERT_PATH=
WEB_SSL_KEY_PATH=
WEB_SSL_CA_PATH=
